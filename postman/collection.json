{
  "info": {
    "name": "Lab14 — Mini Book API",
    "_postman_id": "lab14-book-api-collection",
    "description": "F.CSM311 Бие даалт 14 — Mini Book API тест (Хувилбар 3)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Сервер ажиллаж байгаа эсэхийг шалгана"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response time < 1000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "pm.test('Content-Type is JSON', () => {",
                  "  pm.response.to.have.header('Content-Type');",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "pm.test('Body has status ok', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('status');",
                  "  pm.expect(d.status).to.eql('ok');",
                  "});",
                  "pm.test('Body has timestamp', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('timestamp');",
                  "  pm.expect(d.timestamp).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "GET all books (Happy GET)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            },
            "description": "Бүх номын жагсаалтыг авна — happy path"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Pre-request: request хийх хугацааг хадгалах",
                  "pm.environment.set('requestTimestamp', new Date().toISOString());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response time < 1000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "pm.test('Content-Type is JSON', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "pm.test('Body schema valid: success, data, total', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('success');",
                  "  pm.expect(d).to.have.property('data');",
                  "  pm.expect(d).to.have.property('total');",
                  "  pm.expect(d.success).to.be.true;",
                  "  pm.expect(d.data).to.be.an('array');",
                  "});",
                  "pm.test('Each book has id, title, author', () => {",
                  "  const books = pm.response.json().data;",
                  "  books.forEach(b => {",
                  "    pm.expect(b).to.have.property('id');",
                  "    pm.expect(b).to.have.property('title');",
                  "    pm.expect(b).to.have.property('author');",
                  "    pm.expect(b.id).to.be.a('number');",
                  "    pm.expect(b.title).to.be.a('string');",
                  "  });",
                  "});",
                  "pm.test('total matches data length', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.total).to.eql(d.data.length);",
                  "});",
                  "// Chain: эхний номын id-г дараагийн request-т ашиглана",
                  "const books = pm.response.json().data;",
                  "if (books.length > 0) {",
                  "  pm.environment.set('existingBookId', books[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET book by id (GET by id)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/books/{{existingBookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "{{existingBookId}}"]
            },
            "description": "Тодорхой id-тай номыг авна — chain-д {{existingBookId}} ашигласан"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response time < 1000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "pm.test('Book has correct id', () => {",
                  "  const d = pm.response.json();",
                  "  const expectedId = Number(pm.environment.get('existingBookId'));",
                  "  pm.expect(d.data.id).to.eql(expectedId);",
                  "});",
                  "pm.test('title is non-empty string', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data.title).to.be.a('string').and.have.length.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST create book (POST create)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Driven Development\",\n  \"author\": \"Kent Beck\",\n  \"year\": 2002\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            },
            "description": "Шинэ ном үүсгэж, буцсан id-г дараагийн request-т ашиглана"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Pre-request: random suffix нэмж давхардал гарахгүй болгоно",
                  "const suffix = Math.floor(Math.random() * 10000);",
                  "pm.environment.set('randomSuffix', suffix);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response time < 1000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "pm.test('New book has id (number)', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data).to.have.property('id');",
                  "  pm.expect(d.data.id).to.be.a('number');",
                  "});",
                  "pm.test('Returned title matches sent title', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data.title).to.eql('Test Driven Development');",
                  "});",
                  "pm.test('year is a number', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data.year).to.be.a('number');",
                  "});",
                  "// Chain: шинэ номын id-г хадгалж PUT/DELETE-д ашиглана",
                  "const newId = pm.response.json().data.id;",
                  "pm.environment.set('newBookId', newId);"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT update book (PUT/PATCH)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Driven Development — Updated\",\n  \"year\": 2003\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books/{{newBookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "{{newBookId}}"]
            },
            "description": "POST-оос авсан {{newBookId}}-г ашиглан ном шинэчлэнэ — chain жишээ"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response time < 1000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});",
                  "pm.test('Title updated correctly', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data.title).to.eql('Test Driven Development — Updated');",
                  "});",
                  "pm.test('id unchanged after update', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data.id).to.eql(Number(pm.environment.get('newBookId')));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE book (DELETE)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/books/{{newBookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "{{newBookId}}"]
            },
            "description": "POST-оос үүссэн номыг устгана — 204 хүлээнэ"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204 No Content', () => {",
                  "  pm.response.to.have.status(204);",
                  "});",
                  "pm.test('Response time < 1000ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "GET non-existent book (404 Error case)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/books/999999",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "999999"]
            },
            "description": "Байхгүй id үед 404 буцаахыг шалгана — negative test"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404 Not Found', () => {",
                  "  pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Error body has error field', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('error');",
                  "  pm.expect(d.success).to.be.false;",
                  "});",
                  "pm.test('Error message is string', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.error).to.be.a('string').and.have.length.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST missing title (400 Error case)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"author\": \"Unknown\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            },
            "description": "title байхгүй үед 400 буцаахыг шалгана — body validation negative test"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400 Bad Request', () => {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Error message mentions title', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.error).to.include('title');",
                  "});",
                  "pm.test('success is false', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.success).to.be.false;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST empty body (400 Error case)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            },
            "description": "Хоосон body явуулж 400 авахыг шалгана"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', () => {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "pm.test('Response has error property', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
